# Google Sheets Integration
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
#
# Setup:
# 1. Go to https://console.cloud.google.com → create a project
# 2. Enable "Google Sheets API"
# 3. IAM & Admin → Service Accounts → Create service account
# 4. Create a JSON key, then paste the values below
# 5. Create a Google Sheet with this header row (row 1):
#    Full Name | Email | Phone | University | Field | Year | Interests | Events | IEEE Member | IEEE ID | Submitted At
# 6. Share the sheet with the service account email (Editor access)
# 7. Copy the Sheet ID from the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id_here
